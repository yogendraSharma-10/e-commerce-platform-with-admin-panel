APP_NAME="E-commerce Platform"
APP_ENV=local
APP_KEY=base64:YOUR_GENERATED_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000
LOG_CHANNEL=stack

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce_db
DB_USERNAME=root
DB_PASSWORD=

# Broadcasting, Cache, Queue, Session
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 Storage (Optional, for product images, etc.)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Payment Gateway Configuration
# Default payment gateway to use (e.g., stripe, paypal)
PAYMENT_GATEWAY_DEFAULT=stripe

# Stripe Configuration
STRIPE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# PayPal Configuration (if using PayPal)
# PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
# PAYPAL_SECRET=YOUR_PAYPAL_SECRET
# PAYPAL_MODE=sandbox # or 'live'

# E-commerce Specific Settings
DEFAULT_CURRENCY=USD
SHIPPING_COST_FLAT_RATE=5.00
TAX_RATE_PERCENTAGE=8.25 # Example: 8.25% sales tax

# Admin Panel Settings
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password

# Microservice Integration - Cross-Project Context
# Configuration for the Microservices-based Analytics Dashboard
# This platform sends data to and fetches insights from the external analytics service.
ANALYTICS_SERVICE_URL=http://localhost:3001/api/v1/events # Example URL for the Analytics Dashboard microservice
ANALYTICS_SERVICE_API_KEY=YOUR_ANALYTICS_SERVICE_API_KEY

# Configuration for the AI-Powered Document Categorizer & Search
# Used by ProductCategorizationService to automatically categorize products.
PRODUCT_CATEGORIZATION_SERVICE_URL=http://localhost:3002/api/v1/categorize # Example URL for the AI Categorizer microservice
PRODUCT_CATEGORIZATION_SERVICE_API_KEY=YOUR_AI_CATEGORIZER_API_KEY

# Optional: Reference to other services for potential future integration or context
# BLOG_SERVICE_URL=http://localhost:3003 # For a potential integrated blog (Markdown Blog Generator CLI)
# CHAT_SERVICE_URL=http://localhost:3004 # For customer support chat (Peer-to-Peer Encrypted Chat Application)
# CODE_SNIPPET_MANAGER_URL=http://localhost:3005 # For internal dev tools or product descriptions (Online Code Snippet Manager)
# PORTFOLIO_AGGREGATOR_URL=http://localhost:3006 # For showcasing vendor/seller profiles (Developer Portfolio Aggregator & Showcase)

# Vite / Frontend Assets
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL="${APP_URL}/api" # Base URL for API calls from the Vue frontend